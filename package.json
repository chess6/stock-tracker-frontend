{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.0",
    "@reduxjs/toolkit": "^2.10.1",
    "@svar-ui/react-grid": "^2.3.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "apexcharts": "^5.3.5",
    "axios": "^1.12.2",
    "react": "^19.2.0",
    "react-apexcharts": "^1.8.0",
    "react-dom": "^19.2.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.4",
    "react-scripts": "5.0.1",
    "react-tabulator": "^0.21.0",
    "redux": "^5.0.1",
    "tabulator-tables": "^6.3.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "craco start",
    "build": "craco build",
    "build:check": "CI=true craco build",
    "test": "craco test",
    "lint": "eslint \"src/**/*.{js,jsx}\" --max-warnings 15",
    "test:e2e": "playwright test",
    "pretest:visual": "npx playwright install chromium && DISABLE_ESLINT_PLUGIN=true npm run build",
    "pretest:visual:update": "npx playwright install chromium && DISABLE_ESLINT_PLUGIN=true npm run build",
    "test:smoke": "playwright test e2e/smoke.spec.js",
    "test:large-grid": "playwright test e2e/large-grid.spec.js",
    "test:screener-regression": "playwright test e2e/screener-regression.spec.js",
    "test:visual": "playwright test e2e/visual-regression.spec.js",
    "test:visual:update": "playwright test e2e/visual-regression.spec.js --update-snapshots",
    "qa:frontend": "npm run lint && CI=true npm test -- --watchAll=false --runInBand && npm run test:visual",
    "test:health": "playwright test e2e/health-scan.spec.js",
    "agent:loop": "PYTHONUNBUFFERED=1 python3 -m orchestrator.autonomous_loop",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "proxy": "http://localhost:5000",
  "devDependencies": {
    "@craco/craco": "^7.1.0",
    "@playwright/test": "^1.52.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.1",
    "postcss": "^8.5.15",
    "serve": "^14.2.4",
    "tailwindcss": "^3.4.19"
  }
}
