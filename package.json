  "private": true,
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.0",
    "@reduxjs/toolkit": "^2.10.1",
    "@svar-ui/react-grid": "^2.3.1",
    "@tanstack/react-table": "^8.21.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "apexcharts": "^5.3.5",
    "axios": "^1.12.2",
    "bootstrap": "^5.3.8",
    "react": "^19.2.0",
    "react-apexcharts": "^1.8.0",
    "react-dom": "^19.2.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.4",
    "react-scripts": "5.0.1",
    "react-tabulator": "^0.21.0",
    "reactstrap": "^9.2.3",
    "redux": "^5.0.1",
    "tabulator-tables": "^6.3.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:check": "CI=true react-scripts build",
    "test": "react-scripts test",
    "lint": "eslint \"src/**/*.{js,jsx}\" --max-warnings 15",
    "test:e2e": "playwright test",
    "test:visual": "playwright test e2e/visual-regression.spec.js",
    "test:visual:update": "playwright test e2e/visual-regression.spec.js --update-snapshots",
    "qa:frontend": "npm run lint && CI=true npm test -- --watchAll=false --runInBand && npm run test:visual",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "proxy": "http://localhost:5000",
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "eslint": "^8.57.1",
    "serve": "^14.2.4"
  }
}
